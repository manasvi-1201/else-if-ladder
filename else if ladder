#include <stdio.h>

int main() {
    float marks;

    // Input
    printf("Enter student marks: ");
    scanf("%f", &marks);

    // Else-if ladder for grading
    if (marks >= 90) {
        printf("Grade: A\n");
    }
    else if (marks >= 75) {
        printf("Grade: B\n");
    }
    else if (marks >= 60) {
        printf("Grade: C\n");
    }
    else if (marks >= 50) {
        printf("Grade: D\n");
    }
    else {
        printf("Grade: F (Fail)\n");
    }

    return 0;
}
